# Fastest setup: vercel env pull .env.local (requires npx vercel link first)
# Manual setup: copy this file to .env.local and fill in values

MONGODB_URI=               # MongoDB Atlas → Database → Connect → Drivers
RESEND_API_KEY=            # resend.com → API Keys
GOOGLE_PRIVATE_KEY=        # Google Cloud → Service Accounts → JSON key (replace \n with \\n)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SHEET_ID=           # From the Google Sheet URL
UPSTASH_REDIS_REST_URL=    # upstash.com → Redis → REST API
UPSTASH_REDIS_REST_TOKEN=
OPENAI_API_KEY=            # platform.openai.com → API Keys
TURNSTILE_SECRET_KEY=      # Cloudflare → Turnstile (leave empty to use dev test key)
NEXT_PUBLIC_TURNSTILE_SITE_KEY= # Cloudflare → Turnstile → Site key (public)
TWILIO_ACCOUNT_SID=        # twilio.com → Console Dashboard
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=      # e.g. whatsapp:+14155238886
RUPAM_WHATSAPP_NUMBER=     # e.g. whatsapp:+91XXXXXXXXXX
