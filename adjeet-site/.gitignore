# Gitignore for the adjeet-site Next.js app.
# The authoritative rules live in the repo root ../.gitignore.
# This file extends those rules with Next.js-specific additions that
# some tools (e.g. Vercel CLI, editors) expect to find here.

# ─── Dependencies ─────────────────────────────────────
node_modules/

# ─── Next.js build output ────────────────────────────
.next/
out/
build/

# ─── Environment variables (SECRETS — never commit) ──
.env
.env.*
!.env.example

# ─── TypeScript build artifacts ───────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing artifacts ────────────────────────────────
coverage/
test-results/
playwright-report/
blob-report/

# ─── OS / editor ──────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ─── Vercel ───────────────────────────────────────────
.vercel
