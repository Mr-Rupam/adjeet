# This project's .gitignore is managed at the repo root (../.gitignore).
# This file exists for tools that look for .gitignore in the project directory.

# ─── Dependencies ─────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ──────────────────────────────────────────
.next/
out/
build/

# ─── Environment variables (SECRETS — never commit) ──
.env
.env.*
!.env.example

# ─── TypeScript build artifacts ───────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing ──────────────────────────────────────────
coverage/
test-results/
playwright-report/
blob-report/

# ─── OS files ─────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Debug logs ───────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Certificates ────────────────────────────────────
*.pem

# ─── Vercel ───────────────────────────────────────────
.vercel
